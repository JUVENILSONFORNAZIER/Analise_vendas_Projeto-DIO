(function (w) {
  if (w.exto && w.exto.__loaded) return;

  const exto = (w.exto = w.exto || {});
  exto.__loaded = true;
  const PAGE_REQUEST_TYPE = "EXTENSION_ACTION";
  const PAGE_RESPONSE_TYPE = "EXTENSION_ACTION_RESULT";

  const cantUseMutationObserver = typeof MutationObserver === "undefined";

  function safe(fn) {
    try {
      const result = fn();

      if (result && typeof result.then === "function") {
        result.catch((error) => {
          console.error("[exto] Async callback failed:", error);
        });
      }
    } catch (error) {
      console.error("[exto] Callback failed:", error);
    }
  }

  function qsAll(selector, root) {
    try {
      return Array.from((root || document).querySelectorAll(selector));
    } catch (error) {
      console.error("[exto] Invalid selector:", selector, error);
      return [];
    }
  }

  exto.safe = safe;
  exto.qsAll = qsAll;
  exto.extensionAction = function (action, payload) {
    const requestId =
      typeof crypto !== "undefined" && crypto.randomUUID
        ? crypto.randomUUID()
        : "exto-" + Date.now() + "-" + Math.random().toString(36).slice(2);

    return new Promise((resolve) => {
      function onMessage(event) {
        if (event.source !== w) return;
        if (event.data?.type !== PAGE_RESPONSE_TYPE) return;
        if (event.data?.requestId !== requestId) return;

        w.removeEventListener("message", onMessage);
        resolve(event.data.response);
      }

      w.addEventListener("message", onMessage);
      w.postMessage({
        type: PAGE_REQUEST_TYPE,
        requestId,
        action,
        payload: payload || {}
      }, "*");
    });
  };

  exto.when = function (condFn, cb, delay = 200) {
    function tick() {
      let ok = false;

      try {
        ok = !!condFn();
      } catch (error) {
        console.error("[exto] Condition failed:", error);
      }

      if (ok) {
        safe(cb);
        return;
      }

      setTimeout(tick, delay);
    }

    tick();
  };

  exto.on = function (selector, cb, delay, observeNew) {
    const pollDelay = delay ?? 200;
    const processedAttr = "data-exto-" + Math.random().toString(36).slice(2, 7);

    function mark(nodes) {
      nodes.forEach((node) => node.setAttribute(processedAttr, "1"));
    }

    function freshOnly(nodes) {
      return nodes.filter((node) => !node.hasAttribute(processedAttr));
    }

    function fire() {
      const found = qsAll(selector);
      if (!found.length) return false;

      if (observeNew) {
        const fresh = freshOnly(found);
        if (fresh.length) {
          mark(fresh);
          safe(() => cb(fresh));
        }
        return true;
      }

      mark(found);
      safe(() => cb(found));
      return true;
    }

    if (fire() && !observeNew) return;

    if (!cantUseMutationObserver) {
      const observer = new MutationObserver(() => {
        const ok = fire();
        if (ok && !observeNew) observer.disconnect();
      });

      observer.observe(document.documentElement, {
        childList: true,
        subtree: true
      });

      return;
    }

    function poll() {
      const ok = fire();
      if (ok && !observeNew) return;
      setTimeout(poll, pollDelay);
    }

    setTimeout(poll, pollDelay);
  };

})(window);

(function (w) {
  const exto = (w.exto = w.exto || {});

  function getFileName(url, fallbackName) {
    if (fallbackName) return fallbackName;

    try {
      const pathname = new URL(url, w.location.href).pathname;
      const name = pathname.split("/").pop();
      return name || "download";
    } catch (error) {
      return "download";
    }
  }

  exto.downloadFile = async function (url, options) {
    const settings = options || {};
    const response = await fetch(url, settings.fetchOptions);

    if (!response.ok) {
      throw new Error("Failed to download file: " + response.status);
    }

    const blob = await response.blob();
    const type = settings.type || blob.type || "application/octet-stream";
    const name = getFileName(url, settings.name);

    return new File([blob], name, {
      type,
      lastModified: Date.now()
    });
  };

  exto.setInputFiles = function (input, files) {
    const transfer = new DataTransfer();

    files.forEach((file) => transfer.items.add(file));

    input.files = transfer.files;
    input.dispatchEvent(new Event("input", { bubbles: true }));
    input.dispatchEvent(new Event("change", { bubbles: true }));

    return input.files;
  };
})(window);

